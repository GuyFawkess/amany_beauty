---
import { useTranslations } from '../../i18n';
import { getEntry } from 'astro:content';
import ImagePlaceholder from '../ui/ImagePlaceholder.astro';

const lang = (Astro.params?.lang as 'es' | 'en') || 'es';
const t = useTranslations(lang);

const galleryData = await getEntry('gallery', 'gallery');
const images = galleryData.data.images || [];
---

<section class="gallery-section" id="gallery">
  <div class="gallery-section__container">
    <h2 class="gallery-section__title">
      {t.gallery.title}
    </h2>

    <div class="gallery-grid">
      {/* Render 8 placeholders, or actual images if they exist */}
      {Array.from({ length: 8 }).map((_, index) => {
        const image = images[index];
        return (
          <div class="gallery-grid__item">
            {image ? (
              <img
                src={image.src}
                alt={lang === 'es' ? image.alt : (image.alt_en || image.alt)}
                class="gallery-grid__image"
              />
            ) : (
              <ImagePlaceholder
                aspectRatio="1/1"
                alt="Galería imagen"
              />
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .gallery-section {
    padding: var(--space-section-mobile) 1rem;
    background-color: var(--color-white-warm);
  }

  .gallery-section__container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .gallery-section__title {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 400;
    color: var(--color-text-dark);
    text-align: center;
    margin-bottom: 3rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .gallery-grid__item {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    cursor: pointer;
    transition: transform var(--transition-base);
  }

  .gallery-grid__item:hover {
    transform: scale(1.02);
  }

  .gallery-grid__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .gallery-section {
      padding: var(--space-section-desktop) 2rem;
    }

    .gallery-section__title {
      font-size: var(--text-4xl);
      margin-bottom: 4rem;
    }

    .gallery-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
  }
</style>
