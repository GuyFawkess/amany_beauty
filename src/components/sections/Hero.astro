---
import { getEntry } from 'astro:content';

const lang = (Astro.params?.lang as 'es' | 'en') || 'es';

const generalData = await getEntry('site', 'general');
const { data } = generalData;
---

<section class="scroll-video-hero" id="scroll-hero">
  <div class="scroll-video-sticky">
    <video
      id="heroVideo"
      src="/videoHero.mp4"
      playsinline
      muted
      preload="auto"
    ></video>

    <div class="hero-content" id="heroContent">
      <h1 class="hero__tagline">
        {lang === 'es' ? data.tagline : data.tagline_en}
      </h1>

      <div class="hero__cta">
        <a href={`/${lang}/#about`} class="hero__cta-button hero__cta-button--primary">
          {lang === 'es' ? 'Conócenos' : 'About Us'}
        </a>
        <a href={`/${lang}/#contact`} class="hero__cta-button hero__cta-button--secondary">
          {lang === 'es' ? 'Reservar' : 'Book Now'}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .scroll-video-hero {
    height: 250vh;
    position: relative;
  }

  .scroll-video-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    overflow: hidden;
  }

  .scroll-video-sticky video {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%) scale(1.2);
    object-fit: cover;
    will-change: transform;
  }

  .hero-content {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 2;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.3),
      rgba(0, 0, 0, 0.5)
    );
    padding: 1rem;
    gap: 2rem;
    opacity: 0;
    transition: opacity 0.8s ease-out;
  }

  .hero-content.visible {
    opacity: 1;
  }

  .hero__tagline {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 300;
    color: var(--color-white-warm);
    text-align: center;
    max-width: 700px;
    line-height: 1.3;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.3);
  }

  .hero__cta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 320px;
  }

  .hero__cta-button {
    display: inline-block;
    padding: 1rem 2rem;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    text-align: center;
    text-decoration: none;
    border-radius: 4px;
    transition: all var(--transition-base);
  }

  .hero__cta-button--primary {
    background-color: var(--color-gold);
    color: var(--color-white-warm);
    border: 2px solid var(--color-gold);
  }

  .hero__cta-button--primary:hover {
    background-color: transparent;
    color: var(--color-gold);
  }

  .hero__cta-button--secondary {
    background-color: transparent;
    color: var(--color-white-warm);
    border: 2px solid var(--color-white-warm);
  }

  .hero__cta-button--secondary:hover {
    background-color: var(--color-white-warm);
    color: var(--color-text-dark);
  }

  @media (min-width: 768px) {
    .hero__tagline {
      font-size: var(--text-4xl);
    }

    .hero__cta {
      flex-direction: row;
      max-width: 400px;
    }

    .hero__cta-button {
      flex: 1;
    }
  }

  @media (min-width: 1024px) {
    .hero__tagline {
      font-size: var(--text-5xl);
    }
  }

  /* Móvil — autoplay en lugar de scroll-driven */
  @media (max-width: 768px) {
    .scroll-video-hero {
      height: 100vh;
    }
    .scroll-video-sticky {
      position: relative;
    }
    .hero-content {
      opacity: 1;
    }
    .scroll-video-sticky video {
      transform: translate(-50%, -50%) scale(1);
    }
  }

  /* Respeta preferencia de movimiento reducido */
  @media (prefers-reduced-motion: reduce) {
    .scroll-video-hero {
      height: 100vh;
    }
    .hero-content {
      opacity: 1;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const video = document.getElementById('heroVideo');
    const hero = document.getElementById('scroll-hero');
    const heroContent = document.getElementById('heroContent');

    if (!video || !hero) {
      console.error('No se encontraron los elementos del hero');
      return;
    }

    console.log('Video y hero encontrados');

    // Detectar móvil
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    console.log('Es móvil:', isMobile, 'Movimiento reducido:', prefersReduced);

    if (isMobile || prefersReduced) {
      // En móvil: autoplay una sola vez y parar en el último frame
      video.autoplay = true;
      video.loop = false;
      video.muted = true;
      video.play().catch(err => console.error('Error autoplay:', err));

      // Cuando el video termine, asegurar que se quede en el último frame
      video.addEventListener('ended', () => {
        video.currentTime = video.duration;
        video.pause();
      });

      console.log('Modo móvil: autoplay activado (una vez)');
      return;
    }

    // Desktop: scroll-driven
    video.pause();
    video.currentTime = 0;

    let isVideoReady = false;

    video.addEventListener('loadedmetadata', () => {
      isVideoReady = true;
      console.log('Video listo, duración:', video.duration);
    });

    video.addEventListener('error', (e) => {
      console.error('Error cargando video:', e);
    });

    // Forzar carga
    video.load();

    function updateVideo() {
      if (!isVideoReady || !video.duration) return;

      const heroRect = hero.getBoundingClientRect();
      const heroTop = heroRect.top;
      const heroHeight = hero.offsetHeight;
      const windowHeight = window.innerHeight;

      // Progreso del scroll dentro de la sección
      const scrolled = -heroTop;
      const scrollable = heroHeight - windowHeight;

      if (scrolled <= 0) {
        video.currentTime = 0;
        if (heroContent) heroContent.classList.remove('visible');
        return;
      }

      if (scrolled >= scrollable) {
        video.currentTime = video.duration;
        if (heroContent) heroContent.classList.add('visible');
        return;
      }

      const progress = scrolled / scrollable;

      // El video termina al 50% del scroll
      const videoProgress = Math.min(progress / 0.5, 1);
      video.currentTime = videoProgress * video.duration;

      // Zoom out effect
      const scale = 1.2 - (videoProgress * 0.2);
      video.style.transform = `translate(-50%, -50%) scale(${scale})`;

      // El contenido aparece después del 60% del scroll
      if (progress > 0.6 && heroContent) {
        heroContent.classList.add('visible');
      } else if (heroContent) {
        heroContent.classList.remove('visible');
      }
    }

    // Usar requestAnimationFrame para suavidad
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateVideo();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // Actualizar también al redimensionar
    window.addEventListener('resize', updateVideo);

    // Ejecutar una vez al inicio
    updateVideo();
  });
</script>


