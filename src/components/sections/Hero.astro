---
import { getEntry } from 'astro:content';

const lang = (Astro.params?.lang as 'es' | 'en') || 'es';

const generalData = await getEntry('site', 'general');
const { data } = generalData;
---

<section class="scroll-video-hero" id="scroll-hero">
  <div class="scroll-video-sticky">
    <video
      id="heroVideo"
      playsinline
      muted
      preload="auto"
      poster="/video-poster.jpg"
    >
      <source src="/videoHero.mp4" type="video/mp4" />
      <source src="/videoHero.webm" type="video/webm" />
    </video>

    <div class="hero-content" id="heroContent">
      <h1 class="hero__tagline">
        {lang === 'es' ? data.tagline : data.tagline_en}
      </h1>

      <div class="hero__cta">
        <a href={`/${lang}/#about`} class="hero__cta-button hero__cta-button--primary">
          {lang === 'es' ? 'Conócenos' : 'About Us'}
        </a>
        <a href={`/${lang}/#contact`} class="hero__cta-button hero__cta-button--secondary">
          {lang === 'es' ? 'Reservar' : 'Book Now'}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .scroll-video-hero {
    height: 250vh;
    position: relative;
  }

  .scroll-video-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    overflow: hidden;
  }

  .scroll-video-sticky video {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%) scale(1.2);
    transform-origin: center center;
    object-fit: cover;
    /* Optimizaciones de rendimiento */
    will-change: transform;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transform-style: preserve-3d;
    /* Forzar aceleración por hardware */
    transform: translate3d(-50%, -50%, 0) scale(1.2);
  }

  .hero-content {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 2;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.3),
      rgba(0, 0, 0, 0.5)
    );
    padding: 1rem;
    gap: 2rem;
    opacity: 0;
    transition: opacity 0.8s ease-out;
  }

  .hero-content.visible {
    opacity: 1;
  }

  .hero__tagline {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 300;
    color: var(--color-white-warm);
    text-align: center;
    max-width: 700px;
    line-height: 1.3;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.3);
  }

  .hero__cta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 320px;
  }

  .hero__cta-button {
    display: inline-block;
    padding: 1rem 2rem;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    text-align: center;
    text-decoration: none;
    border-radius: 4px;
    transition: all var(--transition-base);
  }

  .hero__cta-button--primary {
    background-color: var(--color-gold);
    color: var(--color-white-warm);
    border: 2px solid var(--color-gold);
  }

  .hero__cta-button--primary:hover {
    background-color: transparent;
    color: var(--color-gold);
  }

  .hero__cta-button--secondary {
    background-color: transparent;
    color: var(--color-white-warm);
    border: 2px solid var(--color-white-warm);
  }

  .hero__cta-button--secondary:hover {
    background-color: var(--color-white-warm);
    color: var(--color-text-dark);
  }

  @media (min-width: 768px) {
    .hero__tagline {
      font-size: var(--text-4xl);
    }

    .hero__cta {
      flex-direction: row;
      max-width: 400px;
    }

    .hero__cta-button {
      flex: 1;
    }
  }

  @media (min-width: 1024px) {
    .hero__tagline {
      font-size: var(--text-5xl);
    }
  }

  /* Móvil — autoplay en lugar de scroll-driven */
  @media (max-width: 768px) {
    .scroll-video-hero {
      height: 100vh;
    }
    .scroll-video-sticky {
      position: relative;
    }
    .hero-content {
      opacity: 0;
    }
    .scroll-video-sticky video {
      transform: translate(-50%, -50%) scale(1);
    }
  }

  /* Respeta preferencia de movimiento reducido */
  @media (prefers-reduced-motion: reduce) {
    .scroll-video-hero {
      height: 100vh;
    }
    .hero-content {
      opacity: 1;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const video = document.getElementById('heroVideo') as HTMLVideoElement | null;
    const hero = document.getElementById('scroll-hero') as HTMLElement | null;
    const heroContent = document.getElementById('heroContent') as HTMLElement | null;

    if (!video || !hero) {
      console.error('No se encontraron los elementos del hero');
      return;
    }

    // TypeScript now knows video and hero are not null after this point
    const videoEl = video;
    const heroEl = hero;

    console.log('Video y hero encontrados');

    // Detectar móvil
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    console.log('Es móvil:', isMobile, 'Movimiento reducido:', prefersReduced);

    if (isMobile || prefersReduced) {
      // En móvil: autoplay una sola vez y parar en el último frame
      videoEl.autoplay = true;
      videoEl.loop = false;
      videoEl.muted = true;
      videoEl.playsInline = true;

      // Función para intentar reproducir con múltiples intentos
      const attemptPlay = (attempt = 0) => {
        videoEl.play()
          .then(() => {
            console.log('Video reproduciéndose exitosamente en móvil');
          })
          .catch(err => {
            console.error(`Error autoplay intento ${attempt}:`, err);
            if (attempt < 3) {
              // Reintentar con diferentes estrategias
              setTimeout(() => {
                videoEl.load();
                setTimeout(() => attemptPlay(attempt + 1), 300);
              }, 500);
            }
          });
      };

      // Esperar a que el video tenga datos suficientes
      const tryPlayWhenReady = () => {
        if (videoEl.readyState >= 2) { // HAVE_CURRENT_DATA
          attemptPlay();
        } else {
          // Escuchar múltiples eventos para compatibilidad con iOS
          const events = ['loadeddata', 'canplay', 'canplaythrough'];
          const handler = () => {
            events.forEach(ev => videoEl.removeEventListener(ev, handler));
            attemptPlay();
          };
          events.forEach(ev => videoEl.addEventListener(ev, handler, { once: true }));

          // Fallback: intentar después de un tiempo
          setTimeout(() => {
            if (videoEl.readyState >= 2) {
              attemptPlay();
            }
          }, 1000);
        }
      };

      // Iniciar carga del video
      videoEl.load();
      tryPlayWhenReady();

      // Cuando el video termine, mostrar el contenido con transición suave
      videoEl.addEventListener('ended', () => {
        videoEl.currentTime = videoEl.duration;
        videoEl.pause();

        // Mostrar el contenido con transición suave
        if (heroContent) {
          heroContent.style.opacity = '1';
          heroContent.classList.add('visible');
        }
      }, { once: true });

      // Detectar interacción del usuario para retry si autoplay falló
      const retryOnInteraction = () => {
        if (videoEl.paused && videoEl.readyState >= 2) {
          videoEl.play().catch(e => console.warn('Play en interacción fallido:', e));
        }
        // Remover listener después del primer intento
        document.removeEventListener('touchstart', retryOnInteraction);
        document.removeEventListener('click', retryOnInteraction);
      };

      document.addEventListener('touchstart', retryOnInteraction, { once: true, passive: true });
      document.addEventListener('click', retryOnInteraction, { once: true });

      console.log('Modo móvil: autoplay activado (una vez)');
      return;
    }

    // Desktop: scroll-driven - Optimizado para fluidez
    videoEl.pause();
    videoEl.currentTime = 0;

    // Detectar conexión lenta (con type safety)
    let isSlowConnection = false;
    if ('connection' in navigator) {
      const conn = (navigator as any).connection;
      if (conn && conn.effectiveType) {
        isSlowConnection = conn.effectiveType === 'slow-2g' || conn.effectiveType === '2g';
      }
    }

    // Reducir calidad en conexiones lentas o dispositivos móviles
    if (isSlowConnection || isMobile) {
      console.log('Conexión lenta detectada, optimizando video...');
      videoEl.preload = "metadata"; // Solo cargar metadata para ahorrar datos
    } else {
      videoEl.preload = "auto";
    }

    // Forzar formato más eficiente para scroll
    videoEl.playsInline = true;
    videoEl.disablePictureInPicture = true;
    videoEl.disableRemotePlayback = true;

    videoEl.load();

    let isVideoReady = false;
    let videoDuration = 0;
    let lastUpdateTime = 0;
    const minUpdateInterval = 33; // ~30fps (1000/30 ≈ 33ms) - Más suave para scroll

    // Cachear dimensiones que no cambian frecuentemente
    let cachedHeroHeight = 0;
    let cachedWindowHeight = 0;

    // Suavizar transiciones con interpolación
    let animationFrameId: number | null = null;

    videoEl.addEventListener('loadedmetadata', () => {
      isVideoReady = true;
      videoDuration = videoEl.duration;
      console.log('Video listo, duración:', videoDuration);

      // Pre-cachear dimensiones iniciales
      cachedHeroHeight = heroEl.offsetHeight;
      cachedWindowHeight = window.innerHeight;
    });

    videoEl.addEventListener('error', (e) => {
      console.error('Error cargando video:', e);
      // Fallback: mostrar imagen estática si el video falla
      const videoParent = videoEl.parentElement;
      if (videoParent) {
        const fallbackImg = document.createElement('div');
        fallbackImg.style.cssText = `
          position: absolute;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.5));
          z-index: 1;
        `;
        videoParent.appendChild(fallbackImg);
      }
    });

    // Monitorear rendimiento del video
    let frameDrops = 0;
    let lastFrameTime = 0;

    function monitorVideoPerformance() {
      const now = performance.now();
      if (lastFrameTime > 0) {
        const frameInterval = now - lastFrameTime;
        // Si el intervalo entre frames es > 20ms, consideramos que hay lag
        if (frameInterval > 20) {
          frameDrops++;
          if (frameDrops > 10) {
            console.warn(`Posible lag en video: ${frameDrops} frames perdidos`);
            // Reducir calidad si hay mucho lag
            if (videoEl.playbackRate > 0.5) {
              videoEl.playbackRate = 0.5;
            }
          }
        }
      }
      lastFrameTime = now;

      if (videoEl.readyState >= 2) { // Al menos cargado parcialmente
        requestAnimationFrame(monitorVideoPerformance);
      }
    }

    // Iniciar monitoreo cuando el video esté listo
    videoEl.addEventListener('loadeddata', () => {
      requestAnimationFrame(monitorVideoPerformance);
    });

    // Precargar más frames del video
    videoEl.addEventListener('canplaythrough', () => {
      console.log('Video puede reproducirse completamente');
      // Intentar precargar más
      if (videoEl.buffered.length > 0) {
        const bufferedEnd = videoEl.buffered.end(videoEl.buffered.length - 1);
        if (bufferedEnd < videoEl.duration * 0.5) {
          console.log('Buffering adicional para mejorar fluidez');
        }
      }
    });

    // Log de eventos de carga para debug
    videoEl.addEventListener('waiting', () => console.log('Video esperando datos...'));
    videoEl.addEventListener('playing', () => console.log('Video reproduciéndose'));
    videoEl.addEventListener('stalled', () => console.warn('Video stalled - sin datos'));
    videoEl.addEventListener('suspend', () => console.log('Video suspendido para ahorrar recursos'));

    function updateVideo(force = false) {
      const now = performance.now();

      // Throttling: solo actualizar cada 33ms (30fps) para scroll más suave
      if (!force && now - lastUpdateTime < minUpdateInterval) {
        return;
      }

      if (!isVideoReady || !videoDuration) return;

      lastUpdateTime = now;

      const heroRect = heroEl.getBoundingClientRect();
      const heroTop = heroRect.top;

      // Solo recalcular dimensiones cuando cambien significativamente
      if (Math.abs(cachedHeroHeight - heroEl.offsetHeight) > 10) {
        cachedHeroHeight = heroEl.offsetHeight;
      }
      if (Math.abs(cachedWindowHeight - window.innerHeight) > 10) {
        cachedWindowHeight = window.innerHeight;
      }

      // Progreso del scroll dentro de la sección
      const scrolled = -heroTop;
      const scrollable = Math.max(cachedHeroHeight - cachedWindowHeight, 1); // Evitar división por cero

      let progress = 0;
      let targetTime = 0;
      let scale = 1.2;

      if (scrolled <= 0) {
        targetTime = 0;
        scale = 1.2;
        if (heroContent) heroContent.classList.remove('visible');
      } else if (scrolled >= scrollable) {
        targetTime = videoDuration;
        scale = 1.0;
        if (heroContent) heroContent.classList.add('visible');
      } else {
        progress = scrolled / scrollable;

        // El video termina al 50% del scroll
        const videoProgress = Math.min(progress / 0.5, 1);
        targetTime = videoProgress * videoDuration;

        // Zoom out effect
        scale = 1.2 - (videoProgress * 0.2);

        // El contenido aparece después del 60% del scroll
        if (progress > 0.6 && heroContent) {
          heroContent.classList.add('visible');
        } else if (heroContent) {
          heroContent.classList.remove('visible');
        }
      }

      // Usar interpolación suave para el tiempo del video
      if (Math.abs(videoEl.currentTime - targetTime) > 0.05) { // Umbral más pequeño para más suavidad
        // Cancelar animación anterior si existe
        if (animationFrameId) {
          cancelAnimationFrame(animationFrameId);
        }

        // Interpolación lineal suave
        const startTime = videoEl.currentTime;
        const endTime = targetTime;
        const duration = 200; // ms para la transición
        let startTimestamp: number | null = null;

        const animateTime = (timestamp: number) => {
          if (!startTimestamp) startTimestamp = timestamp;
          const elapsed = timestamp - startTimestamp;
          const t = Math.min(elapsed / duration, 1);

          // Easing function para transición más natural
          const easedT = t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;

          videoEl.currentTime = startTime + (endTime - startTime) * easedT;

          if (t < 1) {
            animationFrameId = requestAnimationFrame(animateTime);
          } else {
            animationFrameId = null;
          }
        };

        animationFrameId = requestAnimationFrame(animateTime);
      }

      // Aplicar transformación de zoom
      videoEl.style.transform = `translate3d(-50%, -50%, 0) scale(${scale})`;
    }

    // Optimización: usar Intersection Observer para detectar cuando la sección está visible
    let observer: IntersectionObserver | null = null;
    if ('IntersectionObserver' in window) {
      observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            // Cuando el hero es visible, asegurar que el video esté listo
            if (!isVideoReady) {
              videoEl.load();
            }
          }
        });
      }, {
        threshold: 0.1
      });

      observer.observe(heroEl);
    }

    // Usar requestAnimationFrame con throttling mejorado y debouncing
    let ticking = false;
    let lastScrollY = window.scrollY;
    let lastScrollTime = 0;
    const scrollDebounce = 50; // ms entre actualizaciones

    function handleScroll() {
      const currentScrollY = window.scrollY;
      const currentTime = Date.now();

      // Solo procesar si hay scroll significativo (>3px) y ha pasado el debounce time
      if (Math.abs(currentScrollY - lastScrollY) < 3 ||
          (currentTime - lastScrollTime) < scrollDebounce) {
        return;
      }

      lastScrollY = currentScrollY;
      lastScrollTime = currentTime;

      if (!ticking) {
        requestAnimationFrame(() => {
          updateVideo();
          ticking = false;
        });
        ticking = true;
      }
    }

    // Usar passive scroll listener para mejor rendimiento
    window.addEventListener('scroll', handleScroll, { passive: true });

    // Actualizar también al redimensionar (con debouncing más agresivo)
    let resizeTimeout: NodeJS.Timeout | null = null;
    let lastResizeTime = 0;

    function handleResize() {
      const now = Date.now();
      // Debouncing agresivo: solo actualizar cada 250ms
      if (now - lastResizeTime < 250) {
        if (resizeTimeout) {
          clearTimeout(resizeTimeout);
        }
      }

      lastResizeTime = now;
      if (resizeTimeout) {
        clearTimeout(resizeTimeout);
      }
      resizeTimeout = setTimeout(() => {
        cachedWindowHeight = window.innerHeight;
        cachedHeroHeight = heroEl.offsetHeight;
        updateVideo(true); // Forzar actualización
      }, 250);
    }

    window.addEventListener('resize', handleResize);

    // Cleanup function para limpiar event listeners y animation frames
    function cleanup() {
      window.removeEventListener('scroll', handleScroll);
      window.removeEventListener('resize', handleResize);
      if (animationFrameId) {
        cancelAnimationFrame(animationFrameId);
        animationFrameId = null;
      }
      if (observer) {
        observer.disconnect();
      }
      if (resizeTimeout) {
        clearTimeout(resizeTimeout);
        resizeTimeout = null;
      }
    }

    // Limpiar al salir de la página
    window.addEventListener('beforeunload', cleanup);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        if (animationFrameId) {
          cancelAnimationFrame(animationFrameId);
          animationFrameId = null;
        }
      } else {
        // Al volver a la página, actualizar
        updateVideo(true);
      }
    });

    // Ejecutar una vez al inicio con retraso para permitir carga
    setTimeout(() => updateVideo(true), 300);
  });
</script>


