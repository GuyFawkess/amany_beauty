---
import { getEntry } from 'astro:content';
import ImagePlaceholder from '../ui/ImagePlaceholder.astro';

const lang = (Astro.params?.lang as 'es' | 'en') || 'es';

const generalData = await getEntry('site', 'general');
const { data } = generalData;
---

<section class="hero" id="hero">
  <div class="hero__container">
    <!-- Logo -->
    <div class="hero__logo">
      <img src="/logo.png" alt="Amani Beauty" class="hero__logo-img" />
    </div>

    <!-- Tagline -->
    <h1 class="hero__tagline">
      {lang === 'es' ? data.tagline : data.tagline_en}
    </h1>

    <!-- Hero Image Placeholder -->
    <div class="hero__image">
      <ImagePlaceholder aspectRatio="16/9" alt="Hero image" />
    </div>
  </div>

  <!-- ANIMATION HOOK: parallax/scroll effect goes here -->
</section>

<style>
  .hero {
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1rem;
    background-color: var(--color-white-warm);
  }

  .hero__container {
    max-width: var(--max-width);
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .hero__logo {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .hero__logo-img {
    max-width: 200px;
    height: auto;
  }

  .hero__tagline {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 300;
    color: var(--color-text-dark);
    text-align: center;
    max-width: 600px;
    line-height: 1.3;
  }

  .hero__image {
    width: 100%;
    max-width: 900px;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 6rem 2rem;
    }

    .hero__tagline {
      font-size: var(--text-4xl);
    }

    .hero__logo-img {
      max-width: 240px;
    }
  }

  @media (min-width: 1024px) {
    .hero__tagline {
      font-size: var(--text-5xl);
    }

    .hero__logo-img {
      max-width: 280px;
    }
  }
</style>
