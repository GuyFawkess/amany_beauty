---
import { getEntry } from 'astro:content';

const lang = (Astro.params?.lang as 'es' | 'en') || 'es';

const generalData = await getEntry('site', 'general');
if (!generalData) {
  throw new Error('General site data not found');
}
const { data } = generalData;
---

<section class="scroll-video-hero" id="scroll-hero">
  <div class="scroll-video-sticky">
    <!-- Video con versión móvil y desktop -->
    <video
      id="heroVideo"
      class="hero-video"
      playsinline
      muted
      preload="auto"
      poster="/video-poster.jpg"
    >
      <source src="/videoHeroMobile.mp4" type="video/mp4" media="(max-width: 768px)" />
      <source src="/videoHero.mp4" type="video/mp4" />
    </video>

    <div class="hero-content" id="heroContent">
      <h1 class="hero__tagline">
        {lang === 'es' ? data.tagline : data.tagline_en}
      </h1>

      <div class="hero__cta">
        <a href={`/${lang}/#about`} class="hero__cta-button hero__cta-button--primary">
          {lang === 'es' ? 'Conócenos' : 'About Us'}
        </a>
        <a href={`/${lang}/#contact`} class="hero__cta-button hero__cta-button--secondary">
          {lang === 'es' ? 'Reservar' : 'Book Now'}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .scroll-video-hero {
    height: 100vh;
    position: relative;
  }

  .scroll-video-sticky {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    padding-top: var(--nav-height);
  }

  .hero-video {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform-origin: center center;
    object-fit: cover;
    will-change: transform;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transform: translate3d(-50%, -50%, 0) scale(1);
  }

  .hero-content {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 2;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.3),
      rgba(0, 0, 0, 0.5)
    );
    padding: calc(var(--nav-height) + 2rem) 1rem 1rem;
    gap: 2rem;
    opacity: 0;
    transition: opacity 0.8s ease-out;
  }

  .hero-content.visible {
    opacity: 1;
  }

  .hero__tagline {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 300;
    color: var(--color-white-warm);
    text-align: center;
    max-width: 700px;
    line-height: 1.3;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.3);
  }

  .hero__cta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 320px;
  }

  .hero__cta-button {
    display: inline-block;
    padding: 1rem 2rem;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    text-align: center;
    text-decoration: none;
    border-radius: 4px;
    transition: all var(--transition-base);
  }

  .hero__cta-button--primary {
    background-color: var(--color-gold);
    color: var(--color-white-warm);
    border: 2px solid var(--color-gold);
  }

  .hero__cta-button--primary:hover {
    background-color: transparent;
    color: var(--color-gold);
  }

  .hero__cta-button--secondary {
    background-color: transparent;
    color: var(--color-white-warm);
    border: 2px solid var(--color-white-warm);
  }

  .hero__cta-button--secondary:hover {
    background-color: var(--color-white-warm);
    color: var(--color-text-dark);
  }

  @media (min-width: 768px) {
    .hero__tagline {
      font-size: var(--text-4xl);
    }

    .hero__cta {
      flex-direction: row;
      max-width: 400px;
    }

    .hero__cta-button {
      flex: 1;
    }
  }

  @media (min-width: 1024px) {
    .hero__tagline {
      font-size: var(--text-5xl);
    }
  }

  @media (max-width: 768px) {
    .hero-video {
      transform: translate(-50%, -50%) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-content {
      opacity: 1;
    }
  }
</style>

<script>
  // Check if we're in development mode
  const isDev = import.meta.env?.DEV ?? false;

  const log = {
    info: (...args: unknown[]) => { if (isDev) console.log('[Hero]', ...args); },
    warn: (...args: unknown[]) => { if (isDev) console.warn('[Hero]', ...args); },
    error: (...args: unknown[]) => console.error('[Hero]', ...args),
  };

  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.getElementById('scroll-hero') as HTMLElement | null;
    const heroContent = document.getElementById('heroContent') as HTMLElement | null;
    const videoEl = document.getElementById('heroVideo') as HTMLVideoElement | null;

    if (!hero || !videoEl) {
      log.error('No se encontraron los elementos del hero');
      return;
    }

    log.info('Hero elementos encontrados');

    // Flag para evitar múltiples intentos de reproducción
    let playAttempted = false;
    let playScheduled = false;

    // Configurar video para autoplay
    videoEl.loop = false;
    videoEl.muted = true;
    videoEl.playsInline = true;

    const attemptPlay = (attempt = 0) => {
      // Si ya se está reproduciendo, no hacer nada
      if (!videoEl.paused && !videoEl.ended) {
        log.info('Video ya reproduciéndose, omitiendo intento');
        playAttempted = true;
        return;
      }

      playAttempted = true;
      playScheduled = false;

      videoEl.play()
        .then(() => {
          log.info('Video reproduciéndose exitosamente');
        })
        .catch(err => {
          log.warn(`Error autoplay intento ${attempt}:`, err);
          playAttempted = false;
          if (attempt < 3) {
            setTimeout(() => {
              videoEl.load();
              setTimeout(() => attemptPlay(attempt + 1), 300);
            }, 500);
          }
        });
    };

    const tryPlayWhenReady = () => {
      if (playScheduled) return;

      if (videoEl.readyState >= 2) {
        attemptPlay();
      } else {
        playScheduled = true;
        const events = ['loadeddata', 'canplay', 'canplaythrough'];
        let eventHandled = false;

        const handler = () => {
          if (eventHandled) return;
          eventHandled = true;
          playScheduled = false;
          events.forEach(ev => videoEl.removeEventListener(ev, handler));
          attemptPlay();
        };

        events.forEach(ev => videoEl.addEventListener(ev, handler, { once: true }));

        setTimeout(() => {
          if (!eventHandled && videoEl.readyState >= 2) {
            handler();
          }
          playScheduled = false;
        }, 1000);
      }
    };

    videoEl.load();
    tryPlayWhenReady();

    // Mostrar contenido cuando el video termine
    videoEl.addEventListener('ended', () => {
      videoEl.currentTime = videoEl.duration;
      videoEl.pause();

      if (heroContent) {
        heroContent.style.opacity = '1';
        heroContent.classList.add('visible');
      }
    }, { once: true });

    // Reintentar en interacción del usuario - unificado para evitar duplicados
    let interactionHandled = false;
    const retryOnInteraction = () => {
      if (interactionHandled) return;
      interactionHandled = true;

      // Pequeño delay para evitar que touchstart y click se disparen ambos
      setTimeout(() => {
        if (videoEl.paused && videoEl.readyState >= 2 && !playAttempted) {
          attemptPlay();
        }
        document.removeEventListener('touchstart', retryOnInteraction);
        document.removeEventListener('click', retryOnInteraction);
      }, 50);
    };

    document.addEventListener('touchstart', retryOnInteraction, { once: true, passive: true });
    document.addEventListener('click', retryOnInteraction, { once: true });

    log.info('Modo autoplay activado (una vez)');
  });
</script>


