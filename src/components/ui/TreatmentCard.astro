---
import ImagePlaceholder from './ImagePlaceholder.astro';
import { useTranslations } from '../../i18n';

interface Props {
  name: string;
  name_en: string;
  description?: string;
  description_en?: string;
  duration?: string;
  price?: string;
  image?: string;
  lang: 'es' | 'en';
}

const { name, name_en, description, description_en, duration, price, image, lang } = Astro.props;
const t = useTranslations(lang);
---

<article class="treatment-card" data-animate="fade-up" data-duration="700">
  <div class="treatment-card__image">
    {image ? (
      <img src={image} alt={lang === 'es' ? name : name_en} />
    ) : (
      <ImagePlaceholder aspectRatio="4/3" alt={lang === 'es' ? name : name_en} />
    )}
  </div>

  <div class="treatment-card__content">
    <h3 class="treatment-card__title">
      {lang === 'es' ? name : name_en}
    </h3>

    {(description || description_en) && (
      <p class="treatment-card__description">
        {lang === 'es' ? description : description_en}
      </p>
    )}

    <div class="treatment-card__meta">
      {duration && (
        <div class="treatment-card__meta-item">
          <span class="treatment-card__meta-label">{t.servicePage.duration}:</span>
          <span class="treatment-card__meta-value">{duration}</span>
        </div>
      )}
      {price && (
        <div class="treatment-card__meta-item">
          <span class="treatment-card__meta-label">{t.servicePage.price}:</span>
          <span class="treatment-card__meta-value">{price}</span>
        </div>
      )}
    </div>
  </div>
</article>

<style>
  .treatment-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-white-warm);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-base);
  }

  .treatment-card:hover {
    box-shadow: var(--shadow-md);
  }

  .treatment-card__image {
    width: 100%;
    aspect-ratio: 4/3;
    position: relative;
    overflow: hidden;
  }

  .treatment-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .treatment-card__content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .treatment-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--color-text-dark);
    margin: 0;
  }

  .treatment-card__description {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-gray-soft);
    margin: 0;
  }

  .treatment-card__meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(201, 169, 110, 0.2);
  }

  .treatment-card__meta-item {
    display: flex;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
  }

  .treatment-card__meta-label {
    font-weight: 400;
    color: var(--color-gold);
  }

  .treatment-card__meta-value {
    font-weight: 300;
    color: var(--color-text-dark);
  }

  @media (min-width: 768px) {
    .treatment-card__content {
      padding: 2rem;
    }

    .treatment-card__title {
      font-size: var(--text-2xl);
    }

    .treatment-card__description {
      font-size: var(--text-base);
    }
  }
</style>
