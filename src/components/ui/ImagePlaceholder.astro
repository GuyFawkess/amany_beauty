---
interface Props {
  aspectRatio?: string;
  alt?: string;
  lang?: 'es' | 'en';
}

const { aspectRatio = '16/9', alt = 'Imagen próximamente', lang = 'es' } = Astro.props;

const placeholderText = lang === 'es' ? '— imagen próximamente —' : '— image coming soon —';
---

<div class="image-placeholder" style={`--aspect-ratio: ${aspectRatio};`} role="img" aria-label={alt}>
  <span class="image-placeholder__text">{placeholderText}</span>
</div>

<style>
  .image-placeholder {
    position: relative;
    width: 100%;
    background-color: #F0E8DC;
    aspect-ratio: var(--aspect-ratio, 16 / 9);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .image-placeholder__text {
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    font-style: italic;
    font-weight: 300;
    color: var(--color-gold);
    text-align: center;
    padding: 1rem;
    opacity: 0.6;
  }

  @media (min-width: 768px) {
    .image-placeholder__text {
      font-size: var(--text-base);
    }
  }
</style>
