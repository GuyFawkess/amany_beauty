---
import reviews from '../../data/reviews.json';
---

<section class="landing-testimonials" id="testimonios">
  <div class="landing-testimonials__container">
    <h2 class="landing-testimonials__title">Lo que dicen nuestras clientas</h2>
    <p class="landing-testimonials__subtitle">
      Experiencias reales de personas que ya han transformado su bienestar.
    </p>

    <div class="landing-testimonials__rating">
      <div class="landing-testimonials__stars">
        {[...Array(5)].map(() => (
          <svg class="landing-testimonials__star" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        ))}
      </div>
      <span class="landing-testimonials__rating-value">{reviews.rating} de 5</span>
      <span class="landing-testimonials__total">({reviews.totalReviews} reseñas)</span>
    </div>

    <div class="landing-testimonials__cards">
      {reviews.reviews.map(review => (
        <article class="landing-testimonials__card">
          <div class="landing-testimonials__header">
            <div class="landing-testimonials__stars">
              {[...Array(review.rating)].map(() => (
                <svg class="landing-testimonials__star landing-testimonials__star--small" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            {review.verified && (
              <span class="landing-testimonials__verified">Verificada</span>
            )}
          </div>
          <p class="landing-testimonials__text">{review.text}</p>
          <div class="landing-testimonials__footer">
            <span class="landing-testimonials__name">{review.name}</span>
            <span class="landing-testimonials__date">{review.date}</span>
          </div>
        </article>
      ))}
    </div>

    <a
      href={reviews.googleUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="landing-testimonials__google-link"
    >
      <svg class="landing-testimonials__google-icon" viewBox="0 0 24 24">
        <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      Ver más reseñas en Google
    </a>
  </div>
</section>

<style>
  .landing-testimonials {
    background-color: var(--color-white);
    padding: var(--space-section-mobile) 0;
  }

  .landing-testimonials__container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-sm);
    text-align: center;
  }

  .landing-testimonials__title {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 400;
    color: var(--color-text-dark);
    margin-bottom: 1rem;
  }

  .landing-testimonials__subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--color-gray-soft);
    max-width: 700px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  .landing-testimonials__rating {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .landing-testimonials__stars {
    display: flex;
    gap: 0.25rem;
    color: #FFD700;
  }

  .landing-testimonials__star {
    width: 24px;
    height: 24px;
  }

  .landing-testimonials__star--small {
    width: 20px;
    height: 20px;
  }

  .landing-testimonials__rating-value {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .landing-testimonials__total {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-gray-soft);
  }

  .landing-testimonials__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .landing-testimonials__card {
    background-color: var(--color-cream);
    padding: 2rem;
    border-radius: var(--border-radius-lg);
    text-align: left;
  }

  .landing-testimonials__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .landing-testimonials__verified {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-primary);
    background-color: rgba(59, 130, 246, 0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-weight: 500;
  }

  .landing-testimonials__text {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text-dark);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  .landing-testimonials__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--color-gray-light);
  }

  .landing-testimonials__name {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .landing-testimonials__date {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-gray-soft);
  }

  .landing-testimonials__google-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background-color: var(--color-text-dark);
    color: var(--color-white);
    text-decoration: none;
    border-radius: var(--border-radius-md);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .landing-testimonials__google-link:hover {
    background-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .landing-testimonials__google-icon {
    width: 24px;
    height: 24px;
  }

  @media (min-width: 768px) {
    .landing-testimonials {
      padding: var(--space-section-desktop) 0;
    }

    .landing-testimonials__title {
      font-size: var(--text-4xl);
    }

    .landing-testimonials__cards {
      grid-template-columns: repeat(3, 1fr);
    }

    .landing-testimonials__rating {
      flex-wrap: nowrap;
    }
  }
</style>
