---
interface Props {
  whatsappNumber?: string;
}

const { whatsappNumber = '' } = Astro.props;

const whatsappLink = whatsappNumber ? `https://wa.me/${whatsappNumber}` : '#';
---

<section class="close-section">
  <div class="container">
    <div class="close-content">
      <h2 class="close-title">No tienes que seguir con estrés y tensión</h2>

      <p class="benefit-text">
        En solo 60 minutos, recupera tu equilibrio y bienestar con nuestros tratamientos
        profesionales diseñados para liberar la tensión acumulada.
      </p>

      <a
        href={whatsappLink}
        class="cta-button"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contactar por WhatsApp"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="cta-button__icon">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Reservar Cita
      </a>

      <p class="final-urgency">
        Tu bienestar no puede esperar. ¡Reserva hoy y transforma tu mañana!
      </p>
    </div>
  </div>
</section>

<style>
  .close-section {
    background-color: var(--color-text-dark);
    padding: 5rem 1rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .close-content {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .close-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: white;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .benefit-text {
    font-size: var(--text-xl);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.05rem;
    padding: 0.85rem 2rem;
    border-radius: var(--border-radius-sm);
    background: linear-gradient(135deg, #D4AF37 0%, #F4E4A6 50%, #D4AF37 100%);
    color: var(--color-text-dark);
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
    transition: all 0.3s ease;
    margin-bottom: 2.5rem;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212, 175, 55, 0.4);
    background: linear-gradient(135deg, #C9A832 0%, #E8D896 50%, #C9A832 100%);
  }

  .cta-button__icon {
    width: 20px;
    height: 20px;
  }

  .final-urgency {
    font-size: var(--text-lg);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    font-style: italic;
    margin-top: 0;
  }

  @media (min-width: 768px) {
    .close-section {
      padding: 5rem 1rem;
    }

    .benefit-text {
      font-size: var(--text-2xl);
    }

    .final-urgency {
      font-size: var(--text-xl);
    }
  }

  @media (max-width: 767px) {
    .close-section {
      padding: 3rem 1rem;
    }

    .benefit-text {
      font-size: var(--text-base);
    }

    .final-urgency {
      font-size: var(--text-base);
    }
  }
</style>
