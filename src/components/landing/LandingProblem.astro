---
import { languages } from '../../i18n/index';

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const t = languages[lang].landing.problem;
---

<section class="landing-problem" id="problema">
  <div class="landing-problem__container">
    <h2 class="landing-problem__title" data-animate="fade-up" data-duration="600">{t.title}</h2>

    <div class="landing-problem__list">
      <div class="landing-problem__item" data-animate-delay="1" data-animate="fade-left" data-duration="700">
        <div class="landing-problem__icon landing-problem__icon--spine">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="5" r="2"/>
            <path d="M12 7v10"/>
            <path d="M8 12h8"/>
            <circle cx="12" cy="19" r="2"/>
          </svg>
        </div>
        <span class="landing-problem__bullet">{t.bullet1}</span>
      </div>

      <div class="landing-problem__item" data-animate-delay="2" data-animate="fade-right" data-duration="800">
        <div class="landing-problem__icon landing-problem__icon--stress">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
          </svg>
        </div>
        <span class="landing-problem__bullet">{t.bullet2}</span>
      </div>

      <div class="landing-problem__item" data-animate-delay="3" data-animate="fade-left" data-duration="750">
        <div class="landing-problem__icon landing-problem__icon--sleep">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </div>
        <span class="landing-problem__bullet">{t.bullet3}</span>
      </div>

      <div class="landing-problem__item" data-animate-delay="4" data-animate="fade-right" data-duration="850">
        <div class="landing-problem__icon landing-problem__icon--battery">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="1" y="6" width="18" height="12" rx="2" ry="2"/>
            <path d="M23 13v-2"/>
            <path d="M5 10v4"/>
            <path d="M9 10v4"/>
            <path d="M13 10v4"/>
          </svg>
        </div>
        <span class="landing-problem__bullet">{t.bullet4}</span>
      </div>
    </div>

    <p class="landing-problem__agitation" data-animate="fade-up" data-duration="700">
      {t.agitation}
    </p>

    <p class="landing-problem__transition" data-animate="fade-up" data-duration="800">
      {t.transition}
    </p>
  </div>
</section>

<style>
  .landing-problem {
    background-color: var(--color-cream);
    padding: var(--space-section-mobile) 0;
  }

  .landing-problem__container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-sm);
    text-align: center;
  }

  .landing-problem__title {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    font-weight: 400;
    color: var(--color-text-dark);
    margin-bottom: 2rem;
  }

  .landing-problem__list {
    max-width: 700px;
    margin: 0 auto 2rem;
  }

  .landing-problem__item {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem;
    background-color: var(--color-white);
    border-radius: var(--border-radius-md);
    margin-bottom: 1rem;
    border: 1px solid rgba(44, 44, 44, 0.08);
    transition: all var(--transition-base);
  }

  .landing-problem__item:hover {
    border-color: var(--color-gold);
    box-shadow: 0 4px 16px rgba(201, 169, 110, 0.15);
    transform: translateX(4px);
  }

  .landing-problem__icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(201, 169, 110, 0.15), rgba(201, 169, 110, 0.08));
    border-radius: 12px;
    color: var(--color-gold);
    transition: transform var(--transition-base);
  }

  .landing-problem__item:hover .landing-problem__icon {
    transform: scale(1.1);
  }

  .landing-problem__icon svg {
    width: 26px;
    height: 26px;
    stroke-width: 2.5;
  }

  .landing-problem__bullet {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-text-dark);
    font-weight: 500;
    line-height: 1.5;
  }

  .landing-problem__agitation {
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--color-text-dark);
    max-width: 700px;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
    padding: 2rem;
    background: linear-gradient(135deg, rgba(201, 169, 110, 0.12), rgba(201, 169, 110, 0.05));
    border-left: 4px solid var(--color-gold);
    border-radius: 0 var(--border-radius-md) var(--border-radius-md) 0;
  }

  .landing-problem__transition {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-gold);
    font-style: italic;
    text-align: center;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .landing-problem {
      padding: var(--space-section-desktop) 0;
    }

    .landing-problem__title {
      font-size: var(--text-5xl);
    }

    .landing-problem__agitation {
      font-size: var(--text-xl);
    }

    .landing-problem__item {
      padding: 2rem;
    }

    .landing-problem__icon {
      width: 60px;
      height: 60px;
    }

    .landing-problem__icon svg {
      width: 30px;
      height: 30px;
    }

    .landing-problem__bullet {
      font-size: var(--text-xl);
    }

    .landing-problem__transition {
      font-size: var(--text-3xl);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .landing-problem__item:hover {
      transform: none;
    }

    .landing-problem__item:hover .landing-problem__icon {
      transform: none;
    }
  }
</style>
