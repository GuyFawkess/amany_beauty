---
import LandingTreatmentCard from '../ui/LandingTreatmentCard.astro';
import { languages } from '../../i18n/index';

interface Props {
  whatsappNumber?: string;
  lang?: 'es' | 'en';
}

const { whatsappNumber, lang = 'es' } = Astro.props;
const t = languages[lang].landing.offer;

const treatments = [
  {
    name: t.fullBody.name,
    duration: t.fullBody.duration,
    price: '45€',
    benefits: t.fullBody.benefits,
    image: '/images/services/masajes/full_body.webp',
    whatsappNumber
  },
  {
    name: t.craneofacial.name,
    duration: t.craneofacial.duration,
    price: '32€',
    benefits: t.craneofacial.benefits,
    image: '/images/services/masajes/craneofacial_masaje.webp',
    isFeatured: true,
    whatsappNumber
  },
  {
    name: t.descontracturante.name,
    duration: t.descontracturante.duration,
    price: '47€',
    benefits: t.descontracturante.benefits,
    image: '/images/services/masajes/descontracturante.webp',
    whatsappNumber
  }
];
---

<section class="landing-offer" id="oferta">
  <div class="landing-offer__container">
    <h2 class="landing-offer__title" data-animate="fade-up" data-duration="600">{t.title}</h2>
    <p class="landing-offer__subtitle" data-animate="fade-up" data-duration="700">
      {t.subtitle}
    </p>

    <div class="landing-offer__cards">
      {treatments.map((treatment, i) => (
        <div data-animate="zoom-in" data-duration={String(700 + i * 150)}>
          <LandingTreatmentCard treatment={treatment} lang={lang} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .landing-offer {
    background-color: var(--color-cream);
    padding: var(--space-section-mobile) 0;
  }

  .landing-offer__container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-sm);
    text-align: center;
  }

  .landing-offer__title {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    font-weight: 400;
    color: var(--color-text-dark);
    margin-bottom: 1rem;
  }

  .landing-offer__subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-gray-soft);
    max-width: 700px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  .landing-offer__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .landing-offer {
      padding: var(--space-section-desktop) 0;
    }

    .landing-offer__title {
      font-size: var(--text-5xl);
    }

    .landing-offer__cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
