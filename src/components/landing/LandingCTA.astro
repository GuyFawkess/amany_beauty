---
interface Props {
  whatsappNumber?: string;
}

const { whatsappNumber = '' } = Astro.props;

const whatsappLink = whatsappNumber ? `https://wa.me/${whatsappNumber}` : '#';
---

<section id="reservar" class="cta-section">
  <div class="container">
    <div class="cta-content">
      <h2 class="cta-title">Reserva tu momento de descanso hoy</h2>

      <p class="urgency-text">
        ¡Quedan pocas citas disponibles esta semana! No dejes pasar tu oportunidad de relajarte.
      </p>

      <a
        href={whatsappLink}
        class="cta-button pulse-animation"
        target="_blank"
        rel="noopener noreferrer"
      >
        Reservar por WhatsApp
      </a>

      <ul class="features-list">
        <li class="feature-item">
          <span class="feature-icon">✓</span>
          <span>Respuesta inmediata</span>
        </li>
        <li class="feature-item">
          <span class="feature-icon">✓</span>
          <span>Sin compromiso</span>
        </li>
        <li class="feature-item">
          <span class="feature-icon">✓</span>
          <span>Confirmación en el momento</span>
        </li>
      </ul>

      <div class="location-info">
        <p class="location-text">
          <strong>Ubicación:</strong> Tías, Lanzarote
        </p>
        <p class="parking-info">
          Parking gratuito disponible en la zona
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background-color: var(--color-warm-white);
    padding: 5rem 1rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .cta-content {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--color-text-dark);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .urgency-text {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .cta-button {
    display: inline-block;
    background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
    color: white;
    padding: 1.25rem 3rem;
    border-radius: 50px;
    font-size: 1.25rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.4);
  }

  .pulse-animation {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }

  .features-list {
    list-style: none;
    padding: 0;
    margin: 3rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.1rem;
    color: var(--color-text-dark);
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
    color: white;
    border-radius: 50%;
    font-weight: bold;
    font-size: 0.9rem;
  }

  .location-info {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .location-text {
    font-size: 1.1rem;
    color: var(--color-text-dark);
    margin-bottom: 0.5rem;
  }

  .parking-info {
    font-size: 1rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .cta-section {
      padding: 3rem 1rem;
    }

    .cta-button {
      padding: 1rem 2rem;
      font-size: 1.1rem;
    }

    .features-list {
      margin: 2rem 0;
    }

    .feature-item {
      font-size: 1rem;
    }
  }
</style>
