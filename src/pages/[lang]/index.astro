---
import Layout from '../../components/layout/Layout.astro';
import Hero from '../../components/sections/Hero.astro';
import ServicesSection from '../../components/sections/ServicesSection.astro';
import AboutSection from '../../components/sections/AboutSection.astro';
import GalleryGrid from '../../components/sections/GalleryGrid.astro';
import ContactSection from '../../components/sections/ContactSection.astro';
import WhatsAppButton from '../../components/ui/WhatsAppButton.astro';

export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
---

<Layout
  title={lang === 'es' ? 'Inicio' : 'Home'}
  description={lang === 'es'
    ? 'Amani Beauty by María García - Tu espacio de belleza y bienestar. Masajes, tratamientos de uñas y faciales personalizados.'
    : 'Amani Beauty by María García - Your beauty and wellness space. Personalized massages, nail treatments, and facials.'}
>
  <Hero />
  <ServicesSection />
  <AboutSection />
  <GalleryGrid />
  <ContactSection />
  <WhatsAppButton />
</Layout>
